# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Scrydex (canonical catalog + price source of truth) ---
SCRYDEX_API_KEY=
SCRYDEX_TEAM_ID=dna
# Set to "1"/"true" to request prices+pops on Scrydex calls (credit-gated)
SCRYDEX_PRICES=1
# JPY -> USD conversion applied at ingestion (Japanese Scrydex prices are in yen)
SCRYDEX_JPY_PER_USD=150

# --- Gap-fill / secondary pricing (run any non-Scrydex source past Dan first) ---
PRICECHARTING_API_TOKEN=

# --- Anthropic (scanner vision + AI summaries) ---
ANTHROPIC_API_KEY=

# --- Patreon (supporter tier) ---
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_REDIRECT_URI=

# --- Cron protection ---
CRON_SECRET=
